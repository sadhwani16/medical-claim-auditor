# Databricks
DATABRICKS_HOST=https://your-workspace.azuredatabricks.net
DATABRICKS_TOKEN=dapi_your_token_here

# Sarvam AI (Indian LLM for translation) — get free key at sarvam.ai
SARVAM_API_KEY=your_sarvam_api_key

# LLM Backend: "databricks" | "openai" | "anthropic"
LLM_PROVIDER=databricks
LLM_API_KEY=your_api_key_here
LLM_MODEL=databricks-meta-llama-3-1-70b-instruct

# Delta Lake storage
DELTA_CATALOG=hive_metastore
DELTA_SCHEMA=pmjay_audit

# DBFS paths (use /tmp for free edition)
VECTOR_STORE_PATH=/dbfs/pmjay_audit/vector_store
CLAIMS_UPLOAD_PATH=/dbfs/pmjay_audit/claims
RULES_PATH=/dbfs/pmjay_audit/rules

# Audit sensitivity (0.0-1.0)
FRAUD_THRESHOLD=0.55
